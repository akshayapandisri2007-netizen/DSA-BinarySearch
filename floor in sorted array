class Solution {
    public int findFloor(int[] arr, int x) {
        // code here
        int low = 0, high = arr.length - 1;
        int ans = -1;

        while (low <= high) {
            int mid = (low + high) / 2;

            if (arr[mid] <= x) {
                ans = mid;        // store possible answer
                low = mid + 1;    // move right
            } else {
                high = mid - 1;   // move left
            }
        }

        return ans;
    }
}
