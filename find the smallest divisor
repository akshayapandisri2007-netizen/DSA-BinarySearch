class Solution {
    public int smallestDivisor(int[] nums, int threshold){
        
        int low = 1;
        int high = 0;
        
        // max element find panna (high)
        for (int num : nums) {
            high = Math.max(high, num);
        }
        
        int ans = high;
        
        while (low <= high) {
            int mid = (low + high) / 2; // divisor
            
            int sum = 0;
            
            // sum calculate pannuvom
            for (int num : nums) {
                sum += (num + mid - 1) / mid; // ceil(num/mid)
            }
            
            if (sum <= threshold) {
                ans = mid;          // possible answer
                high = mid - 1;    // smaller try pannuvom
            } else {
                low = mid + 1;     // divisor increase pannum
            }
        }
        
        return ans;
    }
}
